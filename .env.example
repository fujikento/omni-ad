# Copy to .env and fill in. All secrets must be generated, never reused.
# Generate with: openssl rand -hex 32  (or -base64 48)

# --- Required to boot ----------------------------------------------------
POSTGRES_PASSWORD=
JWT_SECRET=
TOKEN_ENCRYPTION_KEY=

# Public URLs the API and web app announce to OAuth providers + browsers.
# Use http://localhost:3000 / 3001 for local dev, https://your-domain
# in production once TLS is configured.
CORS_ORIGIN=http://localhost:3000
OAUTH_REDIRECT_BASE_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000

# --- Optional: AI providers ----------------------------------------------
# Without these the AI Pilot, creative generation, and reporting LLM
# features render empty states.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
RUNWAY_API_KEY=

# --- Optional: ad platform OAuth credentials -----------------------------
# Without these the corresponding platform connector is disabled. Each
# platform requires the matching webhook secret too.
META_CLIENT_ID=
META_CLIENT_SECRET=
META_WEBHOOK_SECRET=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_DEVELOPER_TOKEN=
GOOGLE_WEBHOOK_SECRET=

TIKTOK_APP_ID=
TIKTOK_APP_SECRET=
TIKTOK_WEBHOOK_SECRET=

LINE_YAHOO_CLIENT_ID=
LINE_YAHOO_CLIENT_SECRET=
LINE_WEBHOOK_SECRET=
YAHOO_JAPAN_WEBHOOK_SECRET=

AMAZON_CLIENT_ID=
AMAZON_CLIENT_SECRET=

X_CLIENT_ID=
X_CLIENT_SECRET=
X_WEBHOOK_SECRET=

MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# --- Optional: payment ---------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
