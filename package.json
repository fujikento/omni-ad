{
  "name": "omni-ad",
  "version": "0.1.0",
  "private": true,
  "description": "OMNI-AD - AI-powered multi-channel marketing automation platform",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules",
    "db:migrate": "pnpm --filter @omni-ad/db migrate",
    "db:push": "pnpm --filter @omni-ad/db push",
    "db:studio": "pnpm --filter @omni-ad/db studio",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.4",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "playwright": "^1.59.1",
    "turbo": "^2.9.6"
  },
  "pnpm": {
    "overrides": {
      "esbuild": ">=0.25.0"
    }
  }
}
